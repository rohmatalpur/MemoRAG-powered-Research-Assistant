# ── LLM API Keys ─────────────────────────────────────────
# Only OpenAI is required — used for embeddings, memory LLM, and generation LLM.
OPENAI_API_KEY=your-openai-api-key-here
# ── LLM Models ───────────────────────────────────────────
# Memory LLM: lightweight model for memory extraction and clue generation
# Options: "gpt-4o-mini", "ollama/llama3.1:8b"
MEMORY_LLM_MODEL=gpt-4o-mini

# Generation LLM: high-quality model for final answer + draft generation
# Options: "gpt-4o", "gpt-4o-mini" (cheaper, slightly lower quality)
GENERATION_LLM_MODEL=gpt-4o

# ── Embeddings ────────────────────────────────────────────
# OpenAI embedding model (3072-dim)
EMBEDDING_MODEL=text-embedding-3-large

# ── Infrastructure ────────────────────────────────────────
# These are set automatically in Docker Compose.
# Override here if running services manually.
QDRANT_HOST=localhost
QDRANT_PORT=6333
REDIS_URL=redis://localhost:6379/0
GROBID_URL=http://localhost:8070

# ── Storage ───────────────────────────────────────────────
SQLITE_URL=sqlite:///./data/research_assistant.db
GRAPH_PATH=./data/knowledge_graph.pickle
UPLOAD_DIR=./data/papers

# ── Optional: local Ollama ────────────────────────────────
# If using Ollama instead of OpenAI for the Memory LLM:
# OLLAMA_BASE_URL=http://localhost:11434
# MEMORY_LLM_MODEL=ollama/llama3.1:8b
